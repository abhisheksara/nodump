ANTHROPIC_API_KEY=your_anthropic_api_key_here

DATABASE_URL=postgresql://user:password@localhost:5432/research_feed

# Twitter/X API (optional — leave blank to skip Twitter ingestion)
TWITTER_BEARER_TOKEN=

# Ingestion interval in hours
FETCH_INTERVAL_HOURS=6

# Number of top items to surface per feed
FEED_LIMIT=10

# User profile for relevance engine (comma-separated interests)
USER_INTERESTS=LLMs,agents,applied ML,inference,fine-tuning
